        // Verify new name exists
        let table = db
            .open_table(OpenTableRequest {
                name: "table2".to_string(),
                namespace: vec![],
                index_cache_size: None,
                lance_read_params: None,
            })
            .await
            .unwrap();
        assert_eq!(table.schema().await.unwrap().fields().len(), 1);
    }

